[
  {
    "role_name": "设计者",
    "skill_path": "roles/设计者/skill.md",
    "blocking_mode": "auto",
    "role_type": "producer",
    "outputs": [
      {
        "name": "应用编排方案",
        "path": "产出-app.yaml",
        "type": "deliverable"
      }
