{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "result": {
      "type": "object",
      "required": [
        "verdict",
        "summary"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "oscillation_detected",
            "regression_detected",
            "snapshot_saved"
          ]
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array"
        },
        "errors": {
          "type": "array"
        }
      }
    }
  },
  "required": [
    "result"
  ],
  "_required_files": [
    {
      "name": "版本快照",
      "path": "outputs/versions/app-v{iteration}.yaml",
      "type": "deliverable"
    },
    {
      "name": "版本Diff报告",
      "path": "outputs/版本管理者-diff报告.json",
      "type": "deliverable"
    },
    {
      "name": "振荡诊断报告",
      "path": "outputs/振荡诊断报告.json",
      "type": "deliverable"
    }
  ]
}