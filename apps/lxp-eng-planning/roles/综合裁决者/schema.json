{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "result": {
      "type": "object",
      "required": [
        "verdict",
        "summary"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "challenged",
            "confirmed",
            "deploy_doc_defect"
          ]
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array"
        },
        "errors": {
          "type": "array"
        }
      }
    }
  },
  "required": [
    "result"
  ],
  "_required_files": [
    {
      "name": "最终裁决书",
      "path": "outputs/最终裁决书.md",
      "type": "deliverable"
    },
    {
      "name": "构建报告",
      "path": "outputs/构建报告.md",
      "type": "deliverable"
    }
  ]
}