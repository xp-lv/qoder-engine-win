{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "result": {
      "type": "object",
      "required": [
        "verdict",
        "summary"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "BACKEND_DOC_DEFECT",
            "BOTH_DOC_DEFECT",
            "FRONTEND_DOC_DEFECT",
            "confirmed"
          ]
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array"
        },
        "errors": {
          "type": "array"
        }
      }
    }
  },
  "required": [
    "result"
  ],
  "_required_files": [
    {
      "name": "交叉审核报告",
      "path": "outputs/交叉审核报告.json",
      "type": "process"
    }
  ]
}